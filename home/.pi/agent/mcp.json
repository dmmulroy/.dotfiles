{
  "mcpServers": {
    "cf-portal": {
      "url": "https://portal.mcp.cfdata.org/mcp",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "cloudflare-api": {
      "url": "https://mcp.cloudflare.com/mcp",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "executor": {
      "url": "https://executor.mulroy.ai/mcp",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "uidotsh": {
      "url": "https://ui.sh/mcp?agent=pi",
      "auth": "bearer",
      "bearerTokenEnv": "UIDOTSH_TOKEN",
      "lifecycle": "lazy"
    }
  }
}
