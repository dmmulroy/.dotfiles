{
  "mcp": {
    "servers": {
      "executor": {
        "type": "remote",
        "url": "https://exe.mulroy.ai/mcp?elicitation_mode=native"
      },
      "cf-portal": {
        "type": "remote",
        "url": "https://portal.mcp.cfdata.org/mcp",
        "oauth": {}
      },
      "uidotsh": {
        "type": "remote",
        "url": "https://ui.sh/mcp?agent=pi",
        "headers": {
          "Authorization": "Bearer ${UIDOTSH_TOKEN}"
        },
        "oauth": false
      }
    }
  }
}
