# Main function
main() {
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
        --skip-ssh)
            export SKIP_SSH=true
            shift
            ;;
        --skip-font)
            export SKIP_FONT=true
            shift
            ;;
        --version)
            echo "${SCRIPT_NAME} version ${VERSION}"
            exit 0
            ;;
        -h | --help)
            cmd_help
            exit 0
            ;;
        *)
            break
            ;;
        esac
    done

    # Get command
    local cmd="${1:-help}"
    shift || true

    # Execute command
    case "$cmd" in
    init)
        cmd_init "$@"
        ;;
    update)
        cmd_update "$@"
        ;;
    doctor)
        cmd_doctor "$@"
        ;;
    package)
        cmd_package "$@"
        ;;
    check-packages)
        cmd_check_packages "$@"
        ;;
    retry-failed)
        cmd_retry_failed "$@"
        ;;
    benchmark-shell)
        cmd_benchmark_shell "$@"
        ;;
    gen-ssh-key)
        cmd_gen_ssh_key "$@"
        ;;
    stow)
        cmd_stow "$@"
        ;;
    completions)
        cmd_completions "$@"
        ;;
    link)
        cmd_link "$@"
        ;;
    unlink)
        cmd_unlink "$@"
        ;;
    edit)
        cmd_edit "$@"
        ;;
    help)
        cmd_help
        ;;
    *)
        print_error "Unknown command: $cmd"
        echo "Run '${SCRIPT_NAME} help' for usage information"
        exit 1
        ;;
    esac
}

# Run main function
main "$@"
