# ─── nix list editing helpers ───────────────────────────────────────────────
# Insert <name> into a nix list, kept sorted. <marker> is a substring that
# identifies the list's opening line; the list ends at the next "]".
#   quote=1 wraps the entry in quotes (casks/brews); quote=0 is a bare attr.
_nix_list_add() {
    local file="$1" marker="$2" indent="$3" quote="$4" name="$5"
    local entry
    if [[ "$quote" == 1 ]]; then entry="${indent}\"${name}\""; else entry="${indent}${name}"; fi
    local tmp inserted=false inlist=false line trimmed
    tmp=$(mktemp)
    while IFS= read -r line || [[ -n "$line" ]]; do
        if [[ "$inlist" == false && "$line" == *"$marker"* ]]; then
            inlist=true
            echo "$line" >>"$tmp"
            continue
        fi
        if [[ "$inlist" == true && "$line" =~ ^[[:space:]]*\] ]]; then
            [[ "$inserted" == false ]] && echo "$entry" >>"$tmp"
            inserted=true
            inlist=false
            echo "$line" >>"$tmp"
            continue
        fi
        if [[ "$inlist" == true && "$inserted" == false ]]; then
            trimmed="$(echo "$line" | tr -d ' "')"
            trimmed="${trimmed%%#*}"
            if [[ -n "$trimmed" && "$name" < "$trimmed" ]]; then
                echo "$entry" >>"$tmp"
                inserted=true
            fi
        fi
        echo "$line" >>"$tmp"
    done <"$file"
    mv "$tmp" "$file"
}

# Remove any list line whose content (sans spaces/quotes/comment) equals <name>.
_nix_list_remove() {
    local file="$1" name="$2" tmp
    tmp=$(mktemp)
    awk -v n="$name" '{ t=$0; gsub(/[ "]/,"",t); sub(/#.*/,"",t); if (t==n) next; print }' "$file" >"$tmp"
    mv "$tmp" "$file"
}

cmd_package_add() {
    local name="$1"
    local type="${2:-pkg}"

    if [[ -z "$name" ]]; then
        print_error "Package name required"
        print_info "Usage: ${SCRIPT_NAME} package add <name> [pkg|cask]"
        print_info "  pkg  = nixpkgs attribute → ${NIX_PACKAGES##*/} (default)"
        print_info "  cask = Homebrew cask     → ${NIX_HOMEBREW##*/}"
        return 1
    fi

    case "$type" in
    pkg | brew | formula) type="pkg" ;;
    cask) type="cask" ;;
    *)
        print_error "Type must be 'pkg' (nixpkgs) or 'cask' (homebrew)"
        return 1
        ;;
    esac

    print_header "Adding $type: $name"

    if [[ "$type" == "pkg" ]]; then
        if grep -qE "^[[:space:]]+${name}([[:space:]]|\$)" "$NIX_PACKAGES"; then
            print_warning "'$name' already in $(basename "$NIX_PACKAGES")"
            return 0
        fi
        _nix_list_add "$NIX_PACKAGES" "with pkgs; [" "    " 0 "$name"
        print_success "Added '$name' to $(basename "$NIX_PACKAGES")"
    else
        if grep -qE "^[[:space:]]+\"${name}\"" "$NIX_HOMEBREW"; then
            print_warning "'$name' already in $(basename "$NIX_HOMEBREW")"
            return 0
        fi
        _nix_list_add "$NIX_HOMEBREW" "casks = [" "      " 1 "$name"
        print_success "Added cask '$name' to $(basename "$NIX_HOMEBREW")"
    fi

    if confirm "Apply now (darwin-rebuild switch)?" "y"; then
        _darwin_switch
    else
        print_info "Run '${SCRIPT_NAME} package update' or 'darwin-rebuild switch' to apply"
    fi
}

cmd_package_remove() {
    local name="$1"

    if [[ -z "$name" ]]; then
        print_error "Package name required"
        print_info "Usage: ${SCRIPT_NAME} package remove <name>"
        return 1
    fi

    print_header "Removing package: $name"

    local in_pkg=false in_cask=false
    grep -qE "^[[:space:]]+${name}([[:space:]]|\$)" "$NIX_PACKAGES" && in_pkg=true
    grep -qE "^[[:space:]]+\"${name}\"" "$NIX_HOMEBREW" && in_cask=true

    if [[ "$in_pkg" == false && "$in_cask" == false ]]; then
        print_warning "'$name' not found in $(basename "$NIX_PACKAGES") or $(basename "$NIX_HOMEBREW")"
        return 0
    fi

    [[ "$in_pkg" == true ]] && {
        _nix_list_remove "$NIX_PACKAGES" "$name"
        print_success "Removed '$name' from $(basename "$NIX_PACKAGES")"
    }
    [[ "$in_cask" == true ]] && {
        _nix_list_remove "$NIX_HOMEBREW" "$name"
        print_success "Removed '$name' from $(basename "$NIX_HOMEBREW")"
    }

    # Casks: cleanup="none" means a switch won't uninstall a removed cask — note it.
    if [[ "$in_cask" == true ]]; then
        print_info "Note: homebrew cleanup is 'none'; run 'brew uninstall --cask $name' to remove the app, or set onActivation.cleanup = \"zap\"."
    fi

    if confirm "Apply now (darwin-rebuild switch)?" "y"; then
        _darwin_switch
    else
        print_info "Run '${SCRIPT_NAME} package update' or 'darwin-rebuild switch' to apply"
    fi
}

cmd_package_update() {
    print_header "Updating packages"
    print_info "Updating flake inputs (nixpkgs + nix-darwin)..."
    _fix_flake_lock_owner
    if ! nix flake update --flake "$DOTFILES_DIR"; then
        print_error "nix flake update failed"
        return 1
    fi
    print_info "Applying configuration..."
    if _darwin_switch; then
        print_success "Packages updated"
    else
        print_error "darwin-rebuild switch failed"
        return 1
    fi
}

cmd_package_list() {
    print_header "Listing packages"

    echo -e "\n${BOLD}nixpkgs — environment.systemPackages ($(basename "$NIX_PACKAGES")):${RESET}"
    # List items are 4-space-indented bare attrs inside the `with pkgs; [ ]` block.
    grep -E '^    [a-zA-Z0-9]' "$NIX_PACKAGES" 2>/dev/null | sed 's/^[[:space:]]*/  - /' || print_info "  none"

    echo -e "\n${BOLD}Homebrew — taps/brews/casks ($(basename "$NIX_HOMEBREW")):${RESET}"
    # Quoted entries inside the homebrew lists.
    grep -E '^[[:space:]]+"' "$NIX_HOMEBREW" 2>/dev/null | tr -d '"' | sed 's/^[[:space:]]*/  - /' | sed 's/#.*//' || print_info "  none"
}

