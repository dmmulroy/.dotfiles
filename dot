cmd_check_packages() {
    print_header "Checking declared packages"

    local missing=()

    # nixpkgs CLI tools: each should resolve on PATH (from the nix profile).
    print_info "Checking nixpkgs packages ($(basename "$NIX_PACKAGES"))..."
    local pkg
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        # Map a few nixpkgs attrs to the binary they actually provide.
        local bin="$pkg"
        case "$pkg" in
        awscli2) bin="aws" ;;
        gnused) bin="sed" ;;
        gnupg) bin="gpg" ;;
        neovim) bin="nvim" ;;
        jujutsu) bin="jj" ;;
        ripgrep) bin="rg" ;;
        esac
        if command_exists "$bin"; then
            installed=$((${installed:-0} + 1))
        else
            missing+=("$pkg (nixpkgs)")
        fi
    done < <(grep -E '^    [a-zA-Z0-9]' "$NIX_PACKAGES" 2>/dev/null | tr -d ' ')

    # Homebrew casks/brews declared in homebrew.nix.
    print_info "Checking Homebrew casks/brews ($(basename "$NIX_HOMEBREW"))..."
    local installed_casks installed_brews
    installed_casks=$(brew list --cask 2>/dev/null || true)
    installed_brews=$(brew list --formula 2>/dev/null || true)
    local entry name
    while IFS= read -r entry; do
        name=$(echo "$entry" | tr -d ' "')
        name="${name%%#*}"
        [[ -z "$name" ]] && continue
        # Taps (owner/tap) aren't formulas/casks — skip them.
        [[ "$name" == */* ]] && continue
        # brew lists casks/brews by their full (possibly @-versioned) name.
        if echo "$installed_casks" | grep -qx "$name" || echo "$installed_brews" | grep -qx "$name"; then
            :
        else
            missing+=("$name (homebrew)")
        fi
    done < <(grep -E '^[[:space:]]+"' "$NIX_HOMEBREW" 2>/dev/null)

    print_header "Package Status Report"
    if [[ ${#missing[@]} -eq 0 ]]; then
        print_success "All declared packages are present"
    else
        print_warning "Not found (${#missing[@]}):"
        printf "  - %s\n" "${missing[@]}"
        echo ""
        print_info "Run '${SCRIPT_NAME} init' or 'darwin-rebuild switch' to apply the configuration"
    fi
}

